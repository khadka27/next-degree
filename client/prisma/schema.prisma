generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    STUDENT
    ADMIN
}

enum ApplicationStatus {
    SAVED
    APPLIED
    ACCEPTED
    REJECTED
}

model User {
    id        String   @id @default(uuid())
    name      String
    username  String   @unique
    email     String   @unique
    password  String
    role      Role     @default(STUDENT)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    profile      StudentProfile?
    applications Application[]
    visaChecks   VisaRateCheck[]
}

model StudentProfile {
    id     String @id @default(uuid())
    userId String @unique
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    nationality      String?
    currentCountry   String?
    gpa              Float?
    yearlyBudget     Float?
    englishScore     Float?
    degreeLevel      String?
    preferredCountry String?
    scholarshipNeeded Boolean? @default(false)
    loanWilling      Boolean?  @default(false)
}

model University {
    id               String   @id @default(uuid())
    name             String
    country          String
    city             String
    ranking          Int?
    tuitionFee       Float
    currency         String   @default("USD")
    avgLivingCost    Float
    ieltsRequirement Float
    degreeLevel      String
    fieldCategory    String
    website          String?
    createdAt        DateTime @default(now())

    applications Application[]
}

model Scholarship {
    id                  String   @id @default(uuid())
    name                String
    country             String
    coverageAmount      Float
    eligibilityCriteria String
    deadline            DateTime
}

model Application {
    id           String            @id @default(uuid())
    studentId    String
    universityId String
    status       ApplicationStatus @default(SAVED)
    createdAt    DateTime          @default(now())

    user       User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
    university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

    @@unique([studentId, universityId])
}

model VisaRateCheck {
    id        String   @id @default(uuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    nationality    String
    destination    String
    degreeLevel    String
    fundsAvailable Float
    ieltsScore     Float?
    pastRejections Int      @default(0)
    
    successRate    Int      // Percentage
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
}
