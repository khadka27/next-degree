generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    STUDENT
    ADMIN
}

enum ApplicationStatus {
    SAVED
    APPLIED
    ACCEPTED
    REJECTED
}

model User {
    id              String    @id @default(uuid())
    name            String
    username        String    @unique
    email           String    @unique
    countryDialCode String?
    phoneNumber     String?
    phoneE164       String?   @unique
    prefersWhatsApp Boolean   @default(true)
    phoneVerified   Boolean   @default(false)
    otpCodeHash     String?
    otpExpiresAt    DateTime?
    otpLastChannel  String?
    password        String
    role            Role      @default(STUDENT)
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    profile         StudentProfile?
    applications    Application[]
    visaChecks      VisaRateCheck[]
    matchingRecords MatchingRecord[]
}

model StudentProfile {
    id     String @id @default(uuid())
    userId String @unique
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    nationality       String?
    currentCountry    String?
    highestEducation  String?
    passingYear       String?
    gpa               Float?
    backlogs          Int?     @default(0)
    studyGap          Int?     @default(0)
    
    // Test Scores
    hasEnglishTest    Boolean?
    testType          String?
    englishScore      Float?
    
    // Aptitude Tests
    aptitudeTest      String?  @default("NONE")
    greVerbal         Float?
    greQuant          Float?
    greAwa            Float?
    gmatTotal         Float?

    // Study Preferences
    degreeLevel       String?
    field             String?
    program           String?
    preferredCountry  String?
    intake            String?
    
    // Financials
    yearlyBudget      Float?
    currency          String?  @default("USD")
    bankBalance       Float?
    sponsorType       String?
    sponsorIncome     Float?
    
    // Preferences
    univType          String?
    cityType          String?
    duration          Int?

    // Requirements
    scholarshipNeeded Boolean? @default(false)
    loanWilling       Boolean? @default(false)
    passportReady     Boolean? @default(false)
    testDone          Boolean? @default(false)
    docsReady         Boolean? @default(false)

    // Calculated Scores
    admissionProb     Float?
    visaSuccessProb   Float?
    estimatedAnnualCost Float?

    updatedAt         DateTime @updatedAt
}

model University {
    id               String   @id @default(uuid())
    name             String
    country          String
    city             String
    ranking          Int?
    tuitionFee       Float
    currency         String   @default("USD")
    avgLivingCost    Float
    ieltsRequirement Float
    degreeLevel      String
    fieldCategory    String
    website          String?
    createdAt        DateTime @default(now())

    applications    Application[]
    matchingRecords MatchingRecord[]
}

model Scholarship {
    id                  String   @id @default(uuid())
    name                String
    country             String
    coverageAmount      Float
    eligibilityCriteria String
    deadline            DateTime
}

model Application {
    id           String            @id @default(uuid())
    studentId    String
    universityId String
    status       ApplicationStatus @default(SAVED)
    createdAt    DateTime          @default(now())

    user       User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
    university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

    @@unique([studentId, universityId])
}

model MatchingRecord {
    id     String @id @default(uuid())
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    universityId String?
    university   University? @relation(fields: [universityId], references: [id])

    formData  Json
    matchData Json

    // Explicit calculated stats for tracking
    admissionChance Float?
    visaSuccess     Float?
    costEstimate    Float?

    createdAt DateTime @updatedAt
    updatedAt DateTime @updatedAt
}

model VisaRateCheck {
    id     String @id @default(uuid())
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    nationality    String
    destination    String
    degreeLevel    String
    fundsAvailable Float
    ieltsScore     Float?
    pastRejections Int    @default(0)

    successRate Int // Percentage
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}
